# Payment info shown to customers
COMPANY_BANK_NAME=First Bank
COMPANY_ACCOUNT_NUMBER=1234567890
COMPANY_ACCOUNT_NAME=MedsNear Ltd

# Payout rate
PAYOUT_RATE_PER_UPLOAD=50
